# Valentina Discord Bot - Environment Configuration
#
# Copy this file to `.env.secret` and fill in the required values.
#
# Required values are uncommented.
# Optional values are commented with their default.

# Valentina API Client
VALBOT_API__BASE_URL=
VALBOT_API__API_KEY=
VALBOT_API__DEFAULT_COMPANY_ID=
# VALBOT_API__TIMEOUT=10.0
# VALBOT_API__MAX_RETRIES=5
# VALBOT_API__RETRY_DELAY=1.0
# VALBOT_API__AUTO_RETRY_RATE_LIMIT=true
# VALBOT_API__AUTO_IDEMPOTENCY_KEYS=true
# VALBOT_API__ENABLE_LOGS=false

# Discord
VALBOT_DISCORD__TOKEN=
VALBOT_DISCORD__GUILDS=
VALBOT_DISCORD__OWNER_CHANNELS=
VALBOT_DISCORD__OWNER_IDS=

# Logging
# Log level is one of: DEBUG, INFO, WARNING, ERROR, CRITICAL
# VALBOT_LOG_LEVEL=INFO
# VALBOT_LOG_FILE_PATH=

# SQLite Database
# VALBOT_DATABASE_PATH=data/database.db
